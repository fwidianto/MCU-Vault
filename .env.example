# MCU Vault - Medical Check-Up Document Management System

# Secret key for session management (change in production)
SECRET_KEY=your-secret-key-change-in-production

# Database configuration
DATABASE_URL=sqlite:///mcu_vault.db

# Upload configuration
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216  # 16MB max file size
ALLOWED_EXTENSIONS={'pdf', 'jpg', 'jpeg', 'png'}

# ===========================================
# AI Health Intelligence (Phase 3A)
# Configure ONE of the following providers
# ===========================================

# Option 1: OpenAI (recommended for best results)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4o

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 3: Local LLM (Ollama)
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2